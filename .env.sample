SMTP_EMAIL=
SMTP_PASSWORD=
DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# AgentPome KYR — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets (Apps Script webhook) ───────────────────────────────────────
GOOGLE_SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# ── Admin auth (server-side only — never exposed to browser) ──────────────────
# Password to log in at /admin/login
ADMIN_PASSWORD=

# Long random string — stored in httpOnly cookie after login
# Generate one: openssl rand -base64 32
ADMIN_SESSION_SECRET=

# Used by /api/admin/lead and /api/report/admin to verify requests
ADMIN_API_KEY=

# Forwarded to Apps Script doGet for phone lookup — must match ADMIN_TOKEN in Code.gs
ADMIN_REVIEW_TOKEN=

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=