SMTP_EMAIL=
SMTP_PASSWORD=
DOMAIN=

# ─────────────────────────────────────────────────────────────────────────────
# AgentPome KYR — Environment Variables
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (instant alert when a lead submits) ──────────────────────────────
# 1. Open Telegram → search @BotFather → /newbot → copy the token
# 2. Send any message to your bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Find "chat": { "id": 123456789 } — that's your CHAT_ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets webhook (via Apps Script — no service account needed) ────────
# 1. Open the file: agentpome-kyr-sheets-script.gs  (in this zip)
# 2. Create a new Google Sheet
# 3. Extensions → Apps Script → paste the script → Save
# 4. Run → setupHeaders  (creates the header row once)
# 5. Deploy → New deployment → Web App
#      Execute as: Me
#      Who has access: Anyone
# 6. Click Deploy → copy the Web App URL → paste below
GOOGLE_SHEETS_WEBHOOK_URL=

# Optional: set the same value in the Apps Script (SECRET_TOKEN variable)
# to reject POST requests that don't include this token
SHEETS_WEBHOOK_SECRET=

# ── Supabase (structured DB, CSV export → import to any CRM) ──────────────────
# 1. supabase.com → new project → Settings → API
# 2. SQL Editor → run the CREATE TABLE block from app/api/leads/route.ts
# 3. Export: Table Editor → kyr_leads → ⋮ → Export CSV
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
# Your WhatsApp number with country code, no + sign
NEXT_PUBLIC_WHATSAPP_NUMBER=
